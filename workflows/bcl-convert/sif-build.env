# Declarative build spec for the bcl-convert Apptainer image, consumed by
# scripts/build-sif.sh (the single generic SIF builder). This file is
# `source`d as bash, so values are plain KEY="value" pairs — no logic.
#
# Adding a container workflow? Drop an Apptainer.def + entrypoint.sh + a
# file like this one in workflows/<workflow>/; never write a per-workflow
# build script and never stage build inputs into the checkout. See
# CLAUDE.md "Container image tier".

# Output SIF filename, written to ${PATH_DERIVED}/images/. MUST match the
# `container:` value in this workflow's YAML (1.0.0.yaml) — the CI guard
# test_sif_build_spec.py enforces that parity so the built artifact name
# can't drift from what the orchestrator resolves at run time.
SIF_FILENAME="bcl-convert-4.5.4.sif"

# Licensed/vendored artifacts the build stages from
# ${PATH_DERIVED}/images/sources/ next to the def (Apptainer.def's %files
# references each by bare filename). The bcl-convert RPM is Illumina-EULA
# gated and cannot live in git — the operator places it under sources/ per
# DEPLOY_CHECKLIST.md. Space-separated; leave empty if the def vendors
# nothing from sources/.
SOURCES="bcl-convert-4.5.4-2.el8.x86_64.rpm"

# Idempotency + post-build verification. The builder runs
# `apptainer exec <sif> ${VERIFY_CMD}` and requires the output to match
# the extended-regex VERIFY_MATCH. The patch component is intentionally
# loose so re-vendoring 4.5.4-1 → 4.5.4-2 doesn't trip a needless rebuild.
VERIFY_CMD="bcl-convert --version"
VERIFY_MATCH="bcl-convert Version 4.5.4"

# Optional. The deploy auto-builds every workflow's SIF via deploy/build-sifs.sh
# (invoked by activate.sh). Set AUTO_BUILD="0" to opt this workflow OUT of that
# auto-build — the deploy then skips it and you build it by hand with
# scripts/build-sif.sh. Defaults to on (build) when unset; left unset here.
# AUTO_BUILD="1"

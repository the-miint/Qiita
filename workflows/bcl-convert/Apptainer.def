Bootstrap: docker
From: oraclelinux:8

%labels
    workflow bcl-convert
    version 1.0.0
    bcl-convert-version 4.5.4

%files
    # Illumina-licensed RPM (EULA bars committing to git — see ./.gitignore).
    # `scripts/build-sif.sh bcl-convert` stages this RPM (declared in
    # sif-build.env's SOURCES) from ${PATH_DERIVED}/images/sources/ into a
    # temp build root and runs `apptainer build` from there; the operator's
    # one-time setup step in DEPLOY_CHECKLIST.md places it there before the build.
    #
    # Staged to /opt, NOT /tmp: a privileged `apptainer build` (the deploy's
    # auto-build runs as root) bind-mounts the HOST /tmp over the image's /tmp
    # during %post, which shadows a /tmp-staged file and makes the `dnf install`
    # below fail with "Could not open … rpm". /opt is part of the image and is
    # not bind-mounted, so the staged RPM survives into %post.
    bcl-convert-4.5.4-2.el8.x86_64.rpm /opt/bcl-convert.rpm
    # manifest_writer.py is workflow-agnostic (output-dir walk → manifest.json)
    # and lives in workflows/_shared; every container copies it from there.
    # build-sif.sh mirrors the repo layout in the temp build root and builds
    # from <build>/bcl-convert, so this ../_shared/ relative path resolves.
    ../_shared/manifest_writer.py /opt/qiita/manifest_writer.py
    entrypoint.sh /opt/qiita/entrypoint.sh

%post
    # Fail the build on any error below (apptainer aborts when %post exits
    # non-zero), so a regression surfaces here, not as a broken SIF or a live
    # job. Without this, a failed `dnf install` would be logged and the build
    # would carry on — exactly how the /tmp-shadowing bug produced a confusing
    # "Could not open … rpm" without stopping the build.
    set -e

    # Assert the licensed RPM actually made it into the image (see the /opt vs
    # /tmp note in %files). If staging regresses, fail loudly here with a clear
    # message instead of a cryptic dnf "Can not load RPM file".
    if [ ! -f /opt/bcl-convert.rpm ]; then
        echo "ERROR: /opt/bcl-convert.rpm missing in image — %files staging regressed (see the /opt vs /tmp note above)" >&2
        exit 1
    fi

    # bcl-convert RPM has no implicit deps inside an Oracle Linux 8 base
    # image, but the entrypoint needs `jq` (params.json parsing) and a
    # Python for manifest_writer.py. OL8's default `python3` is 3.6, which
    # predates PEP 585 builtin generics (`list[str]`) and crashes the
    # workflow-agnostic manifest_writer.py at import. Install the appstream
    # python3.11 module instead and invoke it explicitly in entrypoint.sh.
    # dnf install handles both plus the RPM itself in one transaction.
    dnf -y install jq python3.11
    dnf -y install /opt/bcl-convert.rpm
    dnf clean all
    rm /opt/bcl-convert.rpm

    chmod 0755 /opt/qiita/entrypoint.sh
    chmod 0644 /opt/qiita/manifest_writer.py

%test
    # Smoke-test that every binary the entrypoint depends on is callable.
    # `apptainer build` runs %test after %post so a failure here fails the
    # build instead of silently shipping a broken SIF. `set -e` makes every
    # check below gate the build, not just the last one.
    set -e
    bcl-convert --version
    jq --version
    python3.11 --version
    # Guard against the entrypoint drifting back to a bare `python3` (= OL8's
    # 3.6): assert it invokes python3.11 for the manifest writer. The positive
    # match fails (and so fails the build) if the invocation reverts to a bare
    # `python3`, keeping the interpreter name in lockstep with %post and
    # entrypoint.sh.
    grep -q 'python3\.11 /opt/qiita/manifest_writer\.py' /opt/qiita/entrypoint.sh
    # Actually execute manifest_writer.py's module body under the shipped
    # interpreter. `list[str]` annotations are evaluated at def-time, so a
    # too-old Python raises TypeError on import — a runtime failure that
    # py_compile/ast parsing would miss. exec_module runs the body (and its
    # annotation evaluation) without triggering the __main__ guard, so a
    # too-old interpreter fails the build instead of a live job.
    python3.11 -c "import importlib.util as u; s = u.spec_from_file_location('mw', '/opt/qiita/manifest_writer.py'); m = u.module_from_spec(s); s.loader.exec_module(m)"

%runscript
    exec /opt/qiita/entrypoint.sh "$@"

Bootstrap: docker
From: oraclelinux:8

%labels
    workflow bcl-convert
    version 1.0.0
    bcl-convert-version 4.5.4

%files
    # Illumina-licensed RPM (EULA bars committing to git — see ./.gitignore).
    # scripts/build-bcl-convert-sif.sh expects the file at
    # ${QIITA_IMAGES_DIR}/sources/bcl-convert-4.5.4-2.el8.x86_64.rpm and runs
    # `apptainer build` from this %files directive's CWD; the operator's
    # one-time setup step in CHANGELOG.md places it there before the build.
    bcl-convert-4.5.4-2.el8.x86_64.rpm /tmp/bcl-convert.rpm
    # manifest_writer.py is workflow-agnostic (output-dir walk → manifest.json)
    # and lives in workflows/_shared; every container copies it from there.
    # `apptainer build` runs from this workflow dir (workflows/bcl-convert), so
    # the source path is relative to it.
    ../_shared/manifest_writer.py /opt/qiita/manifest_writer.py
    entrypoint.sh /opt/qiita/entrypoint.sh

%post
    # bcl-convert RPM has no implicit deps inside an Oracle Linux 8 base
    # image, but the entrypoint needs `jq` (params.json parsing) and
    # `python3` (manifest_writer.py). dnf install handles both plus the
    # RPM itself in one transaction.
    dnf -y install jq python3
    dnf -y install /tmp/bcl-convert.rpm
    dnf clean all
    rm /tmp/bcl-convert.rpm

    chmod 0755 /opt/qiita/entrypoint.sh
    chmod 0644 /opt/qiita/manifest_writer.py

%test
    # Smoke-test that every binary the entrypoint depends on is callable.
    # `apptainer build` runs %test after %post so a missing dep here fails
    # the build instead of silently shipping a broken SIF.
    bcl-convert --version
    jq --version
    python3 --version

%runscript
    exec /opt/qiita/entrypoint.sh "$@"

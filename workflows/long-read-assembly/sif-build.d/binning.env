# Declarative build spec for the long-read-assembly `binning` image (metawrap),
# consumed by scripts/build-sif.sh via `build-sif.sh long-read-assembly binning`.
# `source`d as bash — plain KEY="value" pairs, no logic. One of four per-tool
# images the workflow ships; see sif-build.d/assemble.env for the layout.

# Output SIF filename; MUST match the `container:` on the `binning` step in
# 1.0.0.yaml (test_sif_build_spec.py enforces this).
SIF_FILENAME="long-read-assembly-binning-1.0.0.sif"

# The def this image builds (workflow-relative).
DEF_FILE="binning.def"

# This image's in-repo build inputs — scopes the idempotency hash to this image.
HASH_INPUTS="binning.sh binning-verify.sh"

# No SOURCES: the conda packages are fetched from bioconda in %post.

# Idempotency + post-build verification.
#
# NOT `micromamba env list` + `metawrap`, which is what this used to be: that
# passes on an env containing zero binners, because bioconda's `metawrap-mg` is
# metaWRAP's scripts only. The image verified clean and every binning job then
# died with `bwa: command not found`. binning-verify.sh checks each tool metaWRAP
# actually invokes and prints the sentinel ONLY when all of them are present — a
# single grep -qE cannot require several tokens, so the all-or-nothing decision
# has to happen inside the script.
VERIFY_CMD="/opt/qiita/binning-verify.sh"
VERIFY_MATCH="BINNING_IMAGE_OK"

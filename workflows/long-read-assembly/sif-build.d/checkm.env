# Declarative build spec for the long-read-assembly `checkm` image (CheckM),
# consumed by scripts/build-sif.sh via `build-sif.sh long-read-assembly checkm`.
# `source`d as bash — plain KEY="value" pairs, no logic. One of four per-tool
# images the workflow ships; see sif-build.d/assemble.env for the layout.

# Output SIF filename; MUST match the `container:` on the `checkm` step in
# 1.0.0.yaml (test_sif_build_spec.py enforces this).
SIF_FILENAME="long-read-assembly-checkm-1.0.0.sif"

# The def this image builds (workflow-relative).
DEF_FILE="checkm.def"

# This image's in-repo build inputs — scopes the idempotency hash to this image.
HASH_INPUTS="checkm.sh"

# No SOURCES: checkm-genome + its external binaries are fetched from bioconda in
# %post. The ~1.4 GB CheckM reference DB is NOT baked in — it is bind-mounted at
# run time (CHECKM_DATA_PATH; see checkm.sh + DEPLOY_CHECKLIST.md).

# Idempotency + post-build verification. `micromamba env list` prints the tool
# env; asserting `checkm` proves it resolved.
VERIFY_CMD="micromamba env list"
VERIFY_MATCH="checkm"

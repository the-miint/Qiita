# Declarative build spec for the long-read-assembly `assemble` image (hifiasm_meta),
# consumed by scripts/build-sif.sh (the single generic SIF builder) via
# `build-sif.sh long-read-assembly assemble`. `source`d as bash — plain KEY="value"
# pairs, no logic. See CLAUDE.md "Container image tier".
#
# One of four per-tool images the workflow ships (assemble / binning / bin_refine /
# checkm), each with its own def + spec so a change to one tool's solve rebuilds
# ONLY that image.

# Output SIF filename, written to ${PATH_DERIVED}/images/. MUST match the
# `container:` value on the `assemble` step in 1.0.0.yaml (test_sif_build_spec.py
# enforces this).
SIF_FILENAME="long-read-assembly-assemble-1.0.0.sif"

# The def this image builds (workflow-relative). Distinguishes it from the other
# three per-tool defs in the same workflow dir.
DEF_FILE="assemble.def"

# This image's in-repo build inputs (workflow-relative), used to SCOPE the
# idempotency hash: the def is auto-included and _shared/manifest_writer.py is
# always hashed, so this lists the entrypoint + shared helper it %files-copies.
# A change to a SIBLING tool's def/entrypoint then leaves this image unchanged.
HASH_INPUTS="_lib.sh assemble.sh"

# No SOURCES: hifiasm_meta is fetched from bioconda in %post (no redistribution
# restriction), so the build stages nothing from the checkout.

# Idempotency + post-build verification. The builder runs
# `apptainer exec <sif> ${VERIFY_CMD}` (word-split, bare tokens — no eval, no
# `$`/backtick) and requires the output to match the extended-regex VERIFY_MATCH.
# `micromamba env list` prints the tool env; asserting `assemble` proves it resolved.
VERIFY_CMD="micromamba env list"
VERIFY_MATCH="assemble"

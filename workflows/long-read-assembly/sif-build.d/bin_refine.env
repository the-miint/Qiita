# Declarative build spec for the long-read-assembly `bin_refine` image (DAS_Tool +
# diamond), consumed by scripts/build-sif.sh via
# `build-sif.sh long-read-assembly bin_refine`. `source`d as bash — plain
# KEY="value" pairs, no logic. One of four per-tool images the workflow ships;
# see sif-build.d/assemble.env for the layout.

# Output SIF filename; MUST match the `container:` on the `bin_refine` step in
# 1.0.0.yaml (test_sif_build_spec.py enforces this). Named for the tool
# (long-read-assembly-dastool) so its reuse in other workflows is unambiguous.
SIF_FILENAME="long-read-assembly-dastool-1.0.0.sif"

# The def this image builds (workflow-relative).
DEF_FILE="bin_refine.def"

# This image's in-repo build inputs — scopes the idempotency hash to this image.
HASH_INPUTS="_lib.sh bin_refine.sh bin_refine.def"

# No SOURCES: das_tool + diamond are fetched from bioconda in %post.

# Idempotency + post-build verification. `micromamba env list` prints the tool
# env; asserting `dastool` proves it resolved.
VERIFY_CMD="micromamba env list"
VERIFY_MATCH="dastool"

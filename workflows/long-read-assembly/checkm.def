Bootstrap: docker
From: mambaorg/micromamba:1.5.8

# Per-tool image for the long-read-assembly `checkm` step (CheckM + pplacer/hmmer/
# prodigal). One of four single-tool images the workflow ships; see assemble.def
# for the split rationale. Invoked as `apptainer exec <sif> /opt/qiita/checkm.sh`
# (per-step entrypoint), so the %runscript is unused.
#
# CheckM reference data (~1.4 GB) is NOT baked in — it is bind-mounted at run time
# from PATH_DERIVED and pointed at via CHECKM_DATA_PATH in checkm.sh.
#
# Pinned invariant: checkm.sh + assembly_load depend on CheckM 1.x's `--tab_table`
# / `qa -o 2` column names — `"Bin Id"`, `"Genome size (bp)"`, `"# contigs"`,
# completeness/contamination — consumed downstream by assembly_load with DuckDB.

%labels
    workflow long-read-assembly
    tool checkm
    version 1.0.0

%files
    # Workflow-agnostic output-dir → manifest.json walker, copied from _shared
    # (build-sif.sh mirrors the repo layout so this relative path resolves).
    ../_shared/manifest_writer.py /opt/qiita/manifest_writer.py
    # Shared entrypoint helpers (params.json parsing, manifest + mode contract).
    ../_shared/_lib.sh /opt/qiita/_lib.sh
    # This image's per-step entrypoint.
    checkm.sh /opt/qiita/checkm.sh

%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH=/opt/conda/bin:${PATH}

%post
    set -e
    export MAMBA_ROOT_PREFIX=/opt/conda
    # jq (params.json), gawk, pigz (fast (de)compress), procps, findutils — the
    # base utilities the entrypoint relies on outside the tool env.
    # `python` is REQUIRED, not a nicety: _lib.sh's qiita_finish runs
    # `python3 /opt/qiita/manifest_writer.py` to emit manifest.json, and EVERY
    # step must write one (the backend verifies it before registering outputs).
    # The micromamba base image ships no Python, so without this every step of
    # this workflow dies at its final line — after doing all its real work.
    # PINNED, like bcl-convert's python3.11: unpinned, a later rebuild silently
    # moves the interpreter major version under manifest_writer.py.
    micromamba install -y -n base -c conda-forge jq gawk pigz procps-ng findutils python=3.11

    # One env for this tool. Channels bioconda + conda-forge; versions pinned
    # loosely here and tightened after the first Linux build resolves the solve.
    #  - checkm: CheckM + its external binaries (pplacer, hmmer, prodigal).
    #
    # Expect a loud, HARMLESS error from checkm-genome's conda post-link script:
    # it tries to `wget` the ~1.4 GB reference DB into the env and fails because
    # wget is not installed. That failure is DESIRABLE and non-fatal — the DB is
    # deliberately not baked in (it is bind-mounted at run time; see the header).
    # Do NOT "fix" it by adding wget: that would silently balloon the image by
    # 1.4 GB and defeat the bind-mount design.
    micromamba create -y -n checkm -c bioconda -c conda-forge checkm-genome pplacer hmmer prodigal

    chmod 0755 /opt/qiita/_lib.sh /opt/qiita/checkm.sh
    chmod 0644 /opt/qiita/manifest_writer.py

    micromamba clean -a -y

%test
    set -e
    # `apptainer build` runs %test inside the FINISHED image — a read-only
    # filesystem — with HOME=/root, a path that lives in that image. libmamba
    # creates a cache dir under $HOME and hard-aborts when it cannot, which failed
    # the very first build of these images. At RUN time this never bites: the SLURM
    # payload passes `--home <workspace>`, a writable dir. So give the test a
    # writable HOME too — and ONLY that, because HOME is the only thing production
    # sets. (Setting XDG_CACHE_HOME as well would be a config no job ever runs
    # under, and would hide it if HOME alone ever stopped being sufficient.) A
    # fresh mktemp dir rather than bare /tmp: private, and it does not leave
    # root-owned litter on the build host.
    export HOME="$(mktemp -d)"
    micromamba env list | grep -q checkm
    # CHECKM_DATA_PATH must be set BEFORE CheckM is imported, exactly as
    # checkm.sh does it at run time. Without it, CheckM's DBManager falls through
    # to `setRoot()` and appends to a DATA_CONFIG file INSIDE site-packages — a
    # write into the image itself, which is read-only both here and at run time:
    #
    #   OSError: [Errno 30] Read-only file system:
    #     '/opt/conda/envs/checkm/lib/python3.11/site-packages/checkm/DATA_CONFIG'
    #
    # (CheckM's own handler for that is `except (IOError, e)`, which raises
    # NameError, so the real error only surfaces as a traceback.) With the var set,
    # it takes the data root from the environment and never writes. Testing `checkm`
    # WITHOUT it would exercise a configuration production never uses — the point
    # here is to fail the BUILD if that assumption ever stops holding, rather than
    # a MAG-producing ticket at run time. The dir need only exist for this import;
    # the real ~1.4 GB DB is bind-mounted at run time.
    export CHECKM_DATA_PATH="${HOME}/checkm_data"
    mkdir -p "${CHECKM_DATA_PATH}"
    micromamba run -n checkm checkm -h >/dev/null
    # Base utilities the entrypoints actually invoke — assert each one, since the
    # whole point of this %test is to fail the BUILD on a missing runtime dep
    # rather than at the end of a long job.
    jq --version
    gawk --version >/dev/null
    find --version >/dev/null
    python3 -c "import importlib.util as u; s=u.spec_from_file_location('mw','/opt/qiita/manifest_writer.py'); m=u.module_from_spec(s); s.loader.exec_module(m)"
    # Lockstep guard (mirrors bcl-convert): if _lib.sh's manifest line ever stops
    # matching what %post installs, fail the BUILD. This bug class — an entrypoint
    # reaching for an interpreter the image lacks — is what killed every step of
    # this workflow at its final line.
    grep -q 'python3 /opt/qiita/manifest_writer\.py' /opt/qiita/_lib.sh
    # Guard the entrypoint stays wired to its env.
    grep -q 'micromamba run -n checkm checkm' /opt/qiita/checkm.sh

%runscript
    echo "long-read-assembly-checkm image: invoke the step entrypoint, e.g." >&2
    echo "  apptainer exec <sif> /opt/qiita/checkm.sh" >&2
    exit 64

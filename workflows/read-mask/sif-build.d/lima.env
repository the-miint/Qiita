# Declarative build spec for the read-mask `lima` image (adapter removal),
# consumed by scripts/build-sif.sh (the single generic SIF builder) via
# `build-sif.sh read-mask lima`. `source`d as bash — plain KEY="value" pairs, no
# logic. See CLAUDE.md "Container image tier".

# Output SIF filename, written to ${PATH_DERIVED}/images/. MUST match the
# `container:` value on the `lima` step in 1.0.0.yaml (test_sif_build_spec.py
# enforces this).
SIF_FILENAME="lima-2.13.0.sif"

DEF_FILE="lima.def"

# This image's in-repo build inputs (workflow-relative), used to SCOPE the
# idempotency hash. The def is auto-included and everything under _shared/ (the
# manifest writer and `_lib.sh`) is always hashed, so neither is listed here; this
# lists the entrypoint and — critically — the ADAPTER FASTA.
#
# Without the FASTA here, re-vendoring the adapter set would NOT rebuild the
# image: the two-gate skip only rebuilds when VERIFY_MATCH fails or the
# build-inputs hash changes, and VERIFY_MATCH is lima's version, which does not
# move when the adapters do. The deploy would silently keep the old SIF.
# (The control plane catches the same drift independently via the adapter md5 it
# folds into the read-mask identity hash.)
HASH_INPUTS="lima.sh twist_adapters_231010.fasta twist_adapters_231010.NOTICE"

# No SOURCES: lima is fetched from bioconda in %post (no redistribution
# restriction), and the adapter FASTA is in-repo, so the build stages nothing from
# ${PATH_DERIVED}/images/sources/.

# Idempotency + post-build verification. The builder runs
# `apptainer exec <sif> ${VERIFY_CMD}` (word-split, bare tokens — no eval, no
# `$`/backtick) and requires the output to match the extended-regex VERIFY_MATCH.
#
# VERIFY_MATCH pins the EXACT lima version, not just its presence: lima decides
# where the adapter clip lands, so the control plane carries this version in the
# read-mask identity hash (`_LIMA_VERSION`) and a CI guard asserts the two agree.
# Bumping lima means bumping the def, this string, and the constant together —
# which re-mints, by design.
VERIFY_CMD="micromamba run -n lima lima --version"
VERIFY_MATCH="lima 2.13.0"

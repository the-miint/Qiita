# Build spec for the SIF-build smoke sentinel (see ./Apptainer.def). Consumed
# by scripts/build-sif.sh exactly like a real workflow's spec — that's the
# point: it drives the generic builder through real apptainer in CI.
#
# No SOURCES: it vendors nothing from images/sources, so the build needs no
# licensed artifact and runs anywhere apptainer is installed.

# Not run by the orchestrator (this is a test sentinel, not an action), so the
# name is arbitrary; it just needs to be stable for the idempotency check.
SIF_FILENAME="qiita-sif-build-smoke.sif"

SOURCES=""

# Verify the ../_shared/manifest_writer.py %files copy resolved and landed at
# /opt/qiita — the relative-path staging is the behavior under test.
VERIFY_CMD="ls /opt/qiita"
VERIFY_MATCH="manifest_writer.py"

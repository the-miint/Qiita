# Declarative build spec for the pacbio-processing Apptainer image, consumed by
# scripts/build-sif.sh (the single generic SIF builder). `source`d as bash —
# plain KEY="value" pairs, no logic. See CLAUDE.md "Container image tier".

# Output SIF filename, written to ${PATH_DERIVED}/images/. MUST match the
# `container:` value in 1.0.0.yaml (the CI guard test_sif_build_spec.py enforces
# this). All four container steps (assemble / binning / bin_refine / checkm)
# share this ONE image via per-step entrypoints, so one build serves the whole
# workflow.
SIF_FILENAME="pacbio-processing-1.0.0.sif"

# No SOURCES: every tool is fetched from bioconda / PyPI in %post (none carry a
# redistribution restriction like bcl-convert's EULA-gated Illumina RPM), so the
# build stages nothing from the checkout.

# Idempotency + post-build verification. The builder runs
# `apptainer exec <sif> ${VERIFY_CMD}` (word-split, bare tokens — no eval, no
# `$`/backtick) and requires the output to match the extended-regex VERIFY_MATCH.
# `micromamba env list` prints the per-tool envs; asserting `metawrap` proves the
# heaviest env resolved, which is the build's real failure point.
VERIFY_CMD="micromamba env list"
VERIFY_MATCH="metawrap"

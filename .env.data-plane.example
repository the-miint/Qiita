# qiita-data-plane environment variables.
#
# Single source of truth for both local-dev and production. systemd loads
# this file format directly (KEY=VALUE, no `export`); local dev sources it
# with `set -a && source .env.data-plane && set +a` (see README).
#
# Usage:
#   Local dev:
#     cp .env.data-plane.example .env.data-plane
#     # edit .env.data-plane and fill in placeholders
#     set -a && source .env.data-plane && set +a
#
#   Production (see docs/runbooks/first-deploy.md step 8b):
#     cp .env.data-plane.example .env.data-plane
#     # edit .env.data-plane: fill in placeholders AND uncomment the
#     # "prod override" lines below the defaults
#     sudo install -m 0440 -o root -g qiita-data \
#         .env.data-plane /etc/qiita/data-plane.env
#
# `.env.data-plane` (without `.example`) is gitignored.

# --- Required -------------------------------------------------------------

# Base64-encoded Ed25519 PUBLIC key (32 bytes) used to VERIFY Flight tickets.
# This is the PUBLIC half of qiita-control-plane's FLIGHT_TICKET_SIGNING_KEY
# keypair (the 'PUBLIC' value from the CP keygen command). The data plane only
# verifies — it cannot sign — so this key is not sensitive.
FLIGHT_TICKET_PUBLIC_KEY=replace-with-the-PUBLIC-value-from-the-keygen-command

# Postgres connection string for the DuckLake catalog.
# Libpq keyword/value format, NOT a `postgresql://` URL.
#
# Dev:  dbname=qiita_ducklake host=localhost port=5432 user=<username>
# Prod: dbname=qiita_miint_lake host=<pg-host> user=qiita_miint_lake_rw password=<password> sslmode=prefer
#       (the runbook sed-substitutes this form into the rendered file in step 8b)
#       sslmode=prefer matches the CP DATABASE_URL — works whether the PG
#       host has SSL enabled or not.
#
# Quoted so the space-separated libpq form and `<placeholder>` syntax both
# survive bash `source`; systemd EnvironmentFile= handles the quotes the same way.
DUCKLAKE_CATALOG_CONNSTR='dbname=qiita_ducklake host=localhost port=5432 user=<username>'

# Absolute path to the shared scratch filesystem root. The data plane
# derives PATH_SCRATCH/staging, under which DoPut writes staged Parquet
# uploads (`PATH_SCRATCH/staging/uploads/{upload_idx}/upload.parquet`).
# MUST be byte-identical to qiita-control-plane's PATH_SCRATCH — the CP
# runner resolves `*_upload_idx` action_context keys against the same
# derived path and the workflow step reads what the DP just wrote.
PATH_SCRATCH=/path/to/shared-scratch

# Absolute path to the persistent (durable, backed-up) filesystem root. The
# data plane derives PATH_PERSISTENT/ducklake, where DuckLake stores its
# Parquet data files — system-of-record state. Required and absolute (no dev
# fallback): a missing value fails fast at boot rather than silently rooting
# durable lake data under /tmp, where it is lost on reboot and never backed up.
PATH_PERSISTENT=/path/to/persistent

# --- Optional (defaults shown) --------------------------------------------

# Address to bind the gRPC server. The systemd template overrides this
# per-instance (e.g. `qiita-data-plane@50051` -> `127.0.0.1:50051`); the
# default below is only consulted when running outside systemd.
# LISTEN_ADDR=0.0.0.0:50051

# Shared dir holding the SINGLE deploy-staged miint extension. The data plane
# does not LOAD miint in production yet, so this is inert today — reserved for
# when it does. When set, the DP LOADs the staged build from here
# (`miint::miint_config` / `load_miint`) instead of installing its own; it must
# be byte-identical to the compute-orchestrator's MIINT_EXTENSION_DIRECTORY (the
# orchestrator stages the build there via scripts/stage-miint-extension.sh), so
# every component runs one build — anything else is drift waiting to happen.
# MIINT_EXTENSION_DIRECTORY=/scratch/persistent/duckdb-ext

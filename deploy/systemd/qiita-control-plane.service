[Unit]
Description=Qiita Control Plane
After=network.target postgresql.service

[Service]
Type=simple
User=qiita-api
ExecStart=/opt/qiita/control-plane/.venv/bin/uvicorn \
    qiita_control_plane.main:app \
    --host 127.0.0.1 \
    --port 8080
Restart=on-failure
EnvironmentFile=/etc/qiita/control-plane.env
# Deploy-owned build stamp (BUILD_SHA), written by deploy/activate.sh on
# every deploy. Optional (leading '-'): absent on first deploy / dev, and
# its absence must never keep the unit down — it only feeds the landing
# footer. Kept separate from the operator-managed control-plane.env above.
EnvironmentFile=-/opt/qiita/control-plane/build.env

# Give the lifespan-shutdown hook room to drain in-flight dispatch
# tasks. The CP itself bounds drain at 60s (see _DISPATCH_DRAIN_TIMEOUT_SECONDS
# in main.py); 90s here leaves headroom for uvicorn's own shutdown path
# before systemd escalates to SIGKILL.
TimeoutStopSec=90s

[Install]
WantedBy=multi-user.target

[Unit]
Description=Qiita Data Plane (instance %i)
After=network.target postgresql.service

[Service]
Type=simple
User=qiita-data
# DuckDB writes its extension cache under $HOME; qiita-data's passwd home is
# /dev/null (non-login svc account), so set a real one via StateDirectory.
StateDirectory=qiita-data
Environment=HOME=/var/lib/qiita-data
Environment=LISTEN_ADDR=127.0.0.1:%i
EnvironmentFile=/etc/qiita/data-plane.env
ExecStart=/opt/qiita/data-plane/qiita-data-plane
Restart=on-failure

[Install]
WantedBy=multi-user.target

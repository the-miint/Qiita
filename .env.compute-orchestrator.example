# qiita-compute-orchestrator environment variables.
#
# Single source of truth for both local-dev and production. systemd loads
# this file format directly (KEY=VALUE, no `export`); local dev sources it
# with `set -a && source .env.compute-orchestrator && set +a` (see README).
#
# Usage:
#   Local dev:
#     cp .env.compute-orchestrator.example .env.compute-orchestrator
#     # edit .env.compute-orchestrator and fill in placeholders
#     set -a && source .env.compute-orchestrator && set +a
#
#   Production (see docs/runbooks/first-deploy.md step 9a):
#     cp .env.compute-orchestrator.example .env.compute-orchestrator
#     # edit .env.compute-orchestrator: fill in placeholders AND uncomment
#     # the "prod override" / SLURM-backend lines below the defaults
#     sudo install -m 0440 -o root -g qiita-orch \
#         .env.compute-orchestrator /etc/qiita/compute-orchestrator.env
#
# `.env.compute-orchestrator` (without `.example`) is gitignored.

# --- CP↔CO shared bearer (always required) --------------------------------
#
# The orchestrator refuses to boot without the CP↔CO token. Production
# loads it from a file at CP_TO_CO_TOKEN_PATH; dev / CI opts into the
# env-var fallback by setting QIITA_ALLOW_TOKEN_ENV=true plus CP_TO_CO_TOKEN.
#
# Dev (env-var fallback — uncomment both):
# QIITA_ALLOW_TOKEN_ENV=true
# CP_TO_CO_TOKEN=replace-with-output-of-openssl-rand-base64-32
#
# Prod uses the file installed in runbook step 7; the optional override is:
# CP_TO_CO_TOKEN_PATH=/etc/qiita/cp-to-co.token

# --- CO→CP outbound auth (always required) --------------------------------
#
# Bearer token the orchestrator presents on outbound calls to the control
# plane (POST /api/v1/sequence-range, future CO→CP endpoints). This is the
# compute-worker service-account PAT — provisioned per
# docs/runbooks/compute-service-account-provisioning.md, distinct from the
# CP↔CO shared bearer above.
#
# Dev (env-var fallback — uncomment both, plus QIITA_ALLOW_TOKEN_ENV=true
# above if not already set):
# CO_TO_CP_TOKEN=replace-with-compute-worker-pat
#
# Prod override path (default /etc/qiita/co-to-cp.token):
# CO_TO_CP_TOKEN_PATH=/etc/qiita/co-to-cp.token

# Control plane base URL the orchestrator hits for outbound calls.
# Defaults to http://localhost:8080 for dev. Prod points at the
# nginx-fronted https origin.
# QIITA_CP_URL=https://qiita-miint.ucsd.edu

# --- Backend selection ----------------------------------------------------

# 'local' runs DuckDB+miint in-process (dev / smoke); 'slurm' submits via
# slurmrestd. Production deploys use 'slurm'.
COMPUTE_BACKEND=local

# Absolute path to the shared scratch filesystem root. The orchestrator's
# readiness probe checks PATH_SCRATCH/ticket for visibility + writability;
# the control plane derives the same PATH_SCRATCH/ticket as the per-ticket
# workspace SLURM jobs run in. In prod this MUST be on the shared
# filesystem so SLURM compute nodes see it too, and MUST be byte-identical
# to the control plane's PATH_SCRATCH.
# Dev default: $TMPDIR/qiita (the CO computes this at startup).
# Prod override (uncomment + edit):
# PATH_SCRATCH=/data

# miint runs the SAME build across every Qiita component — no community-vs-mirror
# patchwork. The deploy stages it ONCE into MIINT_EXTENSION_DIRECTORY
# (scripts/stage-miint-extension.sh); the CO service and native SLURM jobs then
# only LOAD it — no per-job download, no compute-node mirror dependency, no
# writable-$HOME requirement. Point this at a shared dir visible from every
# compute node (parallel to PATH_DERIVED/images, e.g. PATH_DERIVED/duckdb-ext);
# the orchestrator propagates it into each job's environment automatically, and
# the compute-readiness probe LOADs from it. Re-run the stage step on a miint or
# DuckDB version bump (DuckDB namespaces the dir by version+platform).
# MIINT_EXTENSION_DIRECTORY=/scratch/persistent/duckdb-ext
#
# MIINT_EXTENSION_REPO overrides the team mirror with a local/dev extension
# build. It is read only by the deploy staging step and the client-side
# `qiita reference load` CLI install — the cluster LOAD path never reads it.
# Leave unset for the mirror.
# MIINT_EXTENSION_REPO=

# --- SLURM backend (required when COMPUTE_BACKEND=slurm) ------------------
#
# Uncomment and fill in when switching to the SLURM backend:
# SLURMRESTD_URL='http://<slurmrestd-host>:6820'
# SLURMRESTD_JWT_PATH='/etc/qiita/slurmrestd.jwt'
# SLURMRESTD_USER_NAME='qiita-job'
# SLURM_PARTITION='qiita'
# SLURM_ACCOUNT='qiita'
#
# Optional SLURM tuning (defaults shown):
# SLURMRESTD_API_VERSION=v0.0.40
# SLURM_POLL_INTERVAL_SECONDS=10
# SLURM_JOB_TIMEOUT_SECONDS=86400
#
# Python interpreter the native-step SBATCH script invokes. Default
# 'python' assumes compute nodes already have a python with
# qiita_compute_orchestrator installed. Set this to an absolute path on
# the shared filesystem when they don't (e.g.
# /home/qiita/qiita-miint/qiita-compute-orchestrator/.venv/bin/python).
# SLURM_NATIVE_PYTHON=python
#
# SLURM QOS to set on submit. Empty (the default) omits the field so
# slurmrestd applies the submitting user's default QOS. Set this
# explicitly on multi-QOS clusters so the orchestrator doesn't depend
# on per-user defaults.
# SLURM_QOS=qiita_norm

# Absolute path to the derived-artifact filesystem root. Apptainer SIFs
# for container-running workflows (e.g. bcl-convert) live under
# PATH_DERIVED/images. SlurmBackend resolves a YAML `container:` filename
# against PATH_DERIVED/images at submit time; non-SIF values containing
# `://` are passed through as registry URLs. The orchestrator validates
# PATH_DERIVED/images at boot (absolute, exists, is a directory) when
# COMPUTE_BACKEND=slurm. The build script
# `scripts/build-bcl-convert-sif.sh` and the operator's one-time RPM
# placement both reference PATH_DERIVED/images — see DEPLOY_CHECKLIST.md
# for the deploy recipe.
# PATH_DERIVED=/scratch/persistent

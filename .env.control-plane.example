# qiita-control-plane environment variables.
#
# Single source of truth for both local-dev and production. systemd loads
# this file format directly (KEY=VALUE, no `export`); local dev sources it
# with `set -a && source .env.control-plane && set +a` (see README).
#
# Usage:
#   Local dev:
#     cp .env.control-plane.example .env.control-plane
#     # edit .env.control-plane and fill in placeholders
#     set -a && source .env.control-plane && set +a
#
#   Production (see docs/runbooks/first-deploy.md step 1):
#     cp .env.control-plane.example .env.control-plane
#     # edit .env.control-plane: fill in placeholders AND uncomment the
#     # "prod override" lines below the defaults
#     sudo install -m 0440 -o root -g qiita-api \
#         .env.control-plane /etc/qiita/control-plane.env
#
# `.env.control-plane` (without `.example`) is gitignored.

# --- Required -------------------------------------------------------------

# Postgres URL for the control-plane application DB.
# `dbmate up` (via `make migrate`) creates the target database if absent,
# but the Postgres server itself must already be running.
#
# Dev:  postgresql://<username>@localhost:5432/qiita
#       (Homebrew Postgres on macOS defaults to your OS login name with no password)
# Prod: postgresql://qiita_miint_rw:<password>@<pg-host>/qiita_miint
#       (the runbook sed-substitutes this form into the rendered file in step 1)
#
# Values are single-quoted so bash `source` accepts the `<placeholder>`
# syntax literally; systemd EnvironmentFile= treats the quotes the same way.
DATABASE_URL='postgresql://<username>@localhost:5432/qiita'

# Base64-encoded HMAC key used to sign Flight tickets.
# Must decode to at least 16 bytes; generate with: openssl rand -base64 32
# Shared with qiita-data-plane — both services must see the same value.
HMAC_SECRET_KEY=replace-with-output-of-openssl-rand-base64-32

# --- AuthRocket (optional in dev; required in prod) -----------------------
#
# The CP boots without these set, but any OIDC-bearing request will fail
# until they are configured. Dev environments that exercise the auth path
# typically use the stubbed JWKS harness in tests rather than a real realm.
#
# Prod override (uncomment + edit all four):
# AUTHROCKET_ISSUER='https://authrocket.com'
# AUTHROCKET_LOGINROCKET_URL='https://<realm>.loginrocket.com'
# AUTHROCKET_JWKS_URL='https://<realm>.loginrocket.com/connect/jwks'
# QIITA_ENDPOINT_URL='https://qiita.example.org'

# --- Compute orchestrator dispatch ----------------------------------------
#
# When set, the CP fires an in-process asyncio task to call the orchestrator's
# /step/run on every work-ticket submission. Leave unset to run the CP without
# dispatch — every work-ticket creation route returns 503.
# COMPUTE_ORCHESTRATOR_URL=http://127.0.0.1:8081

# --- Optional (defaults shown) --------------------------------------------

# gRPC URL for reaching the data plane.
# DATA_PLANE_URL=grpc://localhost:50051

# Path to the CP↔CO shared bearer token file (see runbook step 7).
# CP_TO_CO_TOKEN_PATH=/etc/qiita/cp-to-co.token

# AuthRocket audience — leave unset; LoginRocket Web JWTs lack `aud`.
# AUTHROCKET_AUDIENCE=

# JWT clock-skew leeway in seconds.
# AUTHROCKET_JWT_LEEWAY_SECONDS=30

# Max age (seconds) of the AuthRocket `auth_time` claim accepted by
# POST /auth/pat. Bounds how long after login a JWT remains usable for
# minting a PAT.
# AUTHROCKET_PAT_MAX_AUTH_AGE_SECONDS=300

# Freshness window for the post-OIDC handoff to the CLI loopback.
# AUTH_HANDOFF_FRESHNESS_SECONDS=60

# TTL for the one-time CLI login code.
# CLI_LOGIN_CODE_TTL_SECONDS=30

# Default TTL (days) for newly-minted PATs.
# QIITA_TOKEN_DEFAULT_TTL_DAYS=90

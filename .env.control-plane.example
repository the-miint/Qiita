# qiita-control-plane environment variables.
#
# Single source of truth for both local-dev and production. systemd loads
# this file format directly (KEY=VALUE, no `export`); local dev sources it
# with `set -a && source .env.control-plane && set +a` (see README).
#
# Usage:
#   Local dev:
#     cp .env.control-plane.example .env.control-plane
#     # edit .env.control-plane and fill in placeholders
#     set -a && source .env.control-plane && set +a
#
#   Production (see docs/runbooks/first-deploy.md step 1):
#     cp .env.control-plane.example .env.control-plane
#     # edit .env.control-plane: fill in placeholders AND uncomment the
#     # "prod override" lines below the defaults
#     sudo install -m 0440 -o root -g qiita-api \
#         .env.control-plane /etc/qiita/control-plane.env
#
# `.env.control-plane` (without `.example`) is gitignored.

# --- Required -------------------------------------------------------------

# Postgres URL for the control-plane application DB.
# `dbmate up` (via `make migrate`) creates the target database if absent,
# but the Postgres server itself must already be running.
#
# Dev:  postgresql://<username>@localhost:5432/qiita
#       (Homebrew Postgres on macOS defaults to your OS login name with no password)
# Prod: postgresql://qiita_miint_rw:<password>@<pg-host>/qiita_miint?sslmode=prefer
#       (the runbook sed-substitutes this form into the rendered file in step 1)
#       sslmode=prefer: lib/pq (used by dbmate) defaults to require; without
#       the explicit prefer, `make migrate` fails when PG has no SSL.
#
# Values are single-quoted so bash `source` accepts the `<placeholder>`
# syntax literally; systemd EnvironmentFile= treats the quotes the same way.
DATABASE_URL='postgresql://<username>@localhost:5432/qiita'

# Base64-encoded Ed25519 PRIVATE seed (32 bytes) used to SIGN Flight tickets.
# The data plane holds only the matching PUBLIC key and verifies, so a
# data-plane compromise can never forge a ticket. Generate the keypair (SIGNING
# value here; PUBLIC value into the data plane's FLIGHT_TICKET_PUBLIC_KEY) with:
#   python3 -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey as K; import base64; k=K.generate(); print('SIGNING', base64.b64encode(k.private_bytes_raw()).decode()); print('PUBLIC', base64.b64encode(k.public_key().public_bytes_raw()).decode())"
FLIGHT_TICKET_SIGNING_KEY=replace-with-the-SIGNING-value-from-the-keygen-command

# Base64-encoded HMAC key for the /auth/login → /auth/handoff cookie.
# DELIBERATELY DISTINCT from FLIGHT_TICKET_SIGNING_KEY so a leak of one can't
# forge the other; control-plane only (the data plane never sees it). Must
# decode to at least 16 bytes; generate its own value with: openssl rand -base64 32
LOGIN_COOKIE_SECRET_KEY=replace-with-a-DIFFERENT-output-of-openssl-rand-base64-32

# Absolute path to the shared scratch filesystem root. The control plane
# derives two subdirs from it:
#   * PATH_SCRATCH/ticket  — per-ticket workspaces the workflow runner
#       mints (`<root>/ticket/<work_ticket_idx>/<step>/attempt-N/`). The
#       CP creates the per-ticket subdir and POSTs its path to the
#       orchestrator as the SLURM job's `current_working_directory`, so
#       the path MUST resolve on every compute node (a shared filesystem).
#   * PATH_SCRATCH/staging — where the data plane writes DoPut uploads
#       (`PATH_SCRATCH/staging/uploads/{upload_idx}/upload.parquet`) and
#       the CP runner resolves `*_upload_idx` action_context keys against.
#
# The orchestrator derives PATH_SCRATCH/ticket and the data plane derives
# PATH_SCRATCH/staging from the SAME PATH_SCRATCH, so set this to a
# byte-identical value in all three env files (control plane, data plane,
# compute orchestrator).
#
# Perms: see docs/runbooks/first-deploy.md §0.3 / §9a — three writers need
# access (qiita-api for the CP runner, qiita-orch for the CO's
# input/output/logs subdirs, qiita-job for SLURM job outputs). The runbook
# spells out which group composition makes that work.
PATH_SCRATCH=/path/to/shared-scratch

# Contact address rendered on the public landing page (`GET /`) as the
# target for both the "request access" and "need help" mailto links.
# Boot fails fast (`CONTACT_EMAIL must be a local@domain address`) if
# unset or malformed. Changing this later is an env-file edit + service
# restart — no code change.
CONTACT_EMAIL=qiita-help@example.org

# --- miint extension (required for long-read-assembly; optional at boot) --
#
# The deploy-staged duckdb-miint extension directory. The CP runner LOADs miint
# in-process to stream a sample's masked reads out as FASTQ (the binding the
# long-read-assembly workflow consumes), so it needs the SAME staged directory
# the compute orchestrator and data plane use — set this byte-identical across
# all three env files, like PATH_SCRATCH.
#
# Service-side miint is LOAD-only and this is why it must be set: with the
# variable unset DuckDB falls back to $HOME/.duckdb/extensions, and the
# qiita-api service account's home is /dev/null, so extension resolution dies
# with `IO Error: Can't find the home directory at '/dev/null'`. The directory
# only needs to be READABLE by qiita-api — a plain LOAD writes nothing.
#
# Unset is tolerated at boot (the CP serves every other route), but any
# long-read-assembly ticket fails at submission with an actionable error.
# MIINT_EXTENSION_DIRECTORY=/scratch/persistent/duckdb-ext

# --- AuthRocket (optional in dev; required in prod) -----------------------
#
# The CP boots without these set, but any OIDC-bearing request will fail
# until they are configured. Dev environments that exercise the auth path
# typically use the stubbed JWKS harness in tests rather than a real realm.
#
# Prod override (uncomment + edit all four):
# AUTHROCKET_ISSUER='https://authrocket.com'
# AUTHROCKET_LOGINROCKET_URL='https://<realm>.loginrocket.com'
# AUTHROCKET_JWKS_URL='https://<realm>.loginrocket.com/connect/jwks'
# QIITA_ENDPOINT_URL='https://qiita.example.org'

# --- Compute orchestrator dispatch ----------------------------------------
#
# When set, the CP fires an in-process asyncio task to call the orchestrator's
# /step/run on every work-ticket submission. Leave unset to run the CP without
# dispatch — every work-ticket creation route returns 503.
# COMPUTE_ORCHESTRATOR_URL=http://127.0.0.1:8081

# --- Optional (defaults shown) --------------------------------------------

# gRPC URL for reaching the data plane.
#
# Point this at the LOOPBACK BALANCER (nginx, plaintext, 127.0.0.1-only), not at
# a data-plane instance directly. The built-in default below addresses instance
# #1, which bypasses the balancer entirely — so every CP-side Flight call
# (register_files, the block/mask/alignment deletes, masked-read DoGets) pins to
# one process no matter how many instances are running. Compute nodes already go
# through nginx (grpc+tls://<host>:443); this is the on-host equivalent, without
# the TLS hop.
#
# DATA_PLANE_URL=grpc://127.0.0.1:50050
#
# Default when unset (single instance, no balancing — fine for local dev):
# DATA_PLANE_URL=grpc://localhost:50051

# Path to the CP↔CO shared bearer token file (see runbook step 7).
# CP_TO_CO_TOKEN_PATH=/etc/qiita/cp-to-co.token

# AuthRocket audience — leave unset; LoginRocket Web JWTs lack `aud`.
# AUTHROCKET_AUDIENCE=

# JWT clock-skew leeway in seconds.
# AUTHROCKET_JWT_LEEWAY_SECONDS=30

# Max age (seconds) of the AuthRocket `auth_time` claim accepted by
# POST /auth/pat. Bounds how long after login a JWT remains usable for
# minting a PAT.
# AUTHROCKET_PAT_MAX_AUTH_AGE_SECONDS=300

# Freshness window for the post-OIDC handoff to the CLI loopback.
# AUTH_HANDOFF_FRESHNESS_SECONDS=60

# TTL for the one-time CLI login code.
# CLI_LOGIN_CODE_TTL_SECONDS=30

# How often the in-process sweeper deletes consumed/expired cli_login_code rows,
# reclaiming any plaintext PAT an abandoned login left at rest.
# CLI_LOGIN_CODE_SWEEP_INTERVAL_SECONDS=60

# Default TTL (days) for newly-minted PATs.
# QIITA_TOKEN_DEFAULT_TTL_DAYS=90

# reference_idx of the canonical `artifact_sequence_set` reference the QC step
# trims adapters against. Required only on a QC-enabled deploy: set it to the
# reference_idx printed when the adapter set is loaded (see DEPLOY_CHECKLIST.md).
# A workflow whose steps need adapters fails its submission when this is unset.
# QIITA_DEFAULT_ADAPTER_REFERENCE_IDX=42

# --- Email notification (work-ticket terminal digests) --------------------
#
# When SMTP_HOST is set, the CP emails a work-ticket's originator once their
# finished tickets settle (a coalesced digest). Leave SMTP_HOST unset to run
# with a no-op transport (no mail; the sweeper still logs what it would send).
# None of these are secrets — the relay is no-auth and IP-allowlisted — so they
# live here, not in a token file.
#
# The live relay (validated end-to-end, delivers internal + external):
# SMTP_HOST=its-smtp-master.ucsd.edu
# SMTP_PORT=25
# SMTP_FROM=donotreply@ucsd.edu
# SMTP_STARTTLS=opportunistic          # opportunistic | required | never
# SMTP_TIMEOUT_SECONDS=15

# Sweeper tuning (defaults shown). Trailing-debounce with a max-wait cap:
# a user's finished tickets coalesce once completions quiesce for
# NOTIFY_QUIET_PERIOD_SECONDS, or unconditionally after NOTIFY_MAX_BATCH_SECONDS
# (so a never-quiescing fanout still flushes). Backlog older than
# NOTIFY_MAX_AGE_SECONDS is drained without emailing; a digest is dead-lettered
# after NOTIFY_MAX_ATTEMPTS failed sends. NOTIFY_MAX_ROWS_PER_SWEEP caps the
# owed rows one pass pulls (bounds memory + advisory-lock hold on a backlog;
# the remainder resumes next pass).
# NOTIFY_SWEEP_INTERVAL_SECONDS=60
# NOTIFY_QUIET_PERIOD_SECONDS=180
# NOTIFY_MAX_BATCH_SECONDS=900
# NOTIFY_MAX_AGE_SECONDS=21600
# NOTIFY_MAX_ATTEMPTS=5
# NOTIFY_MAX_ROWS_PER_SWEEP=5000

# --- Fan-out dispatch throttle (optional) ---
# Per-cohort cap on how many fan-out child work_tickets (sharded reference-index
# build, bulk read-mask block, bulk sharded-alignment block) the control plane
# dispatches at once. A fan-out INSERTs all its children held and releases only
# this many per cohort, refilling as each finishes — so a 1000-shard reference
# build can't open ~1000 concurrent data-plane streams at once. Default 8 (the
# operator throttle that recovered reference 16). Raise once the data plane's
# headroom is known; lower if the data plane is memory/fd-constrained.
# FANOUT_MAX_INFLIGHT=8

<!DOCTYPE html>
<html>
  <body style="font-family: sans-serif; color: #222;">
    <p>Hello,</p>
    <p>
      {{ total }} of your qiita-miint work ticket{{ 's' if total != 1 else '' }}
      reached a final state:
    </p>
    <ul>
      {% for state, n in counts %}
      <li>{{ n }} {{ state }}</li>
      {% endfor %}
    </ul>
    {% if active_total %}
    <p><strong>{{ active_total }} still active</strong> ({{ active_summary }}).</p>
    {% if active_actions %}
    <ul>
      {% for a in active_actions %}
      <li>{{ a.total }} {{ a.action_id }} {{ a.action_version }} ({{ a.summary }})</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% else %}
    <p><strong>No other work tickets of yours are still active.</strong></p>
    {% endif %}
    {% if held_total %}
    <p>
      {{ held_total }} held after exhausting infrastructure retries — redrive with
      <code>qiita ticket run &lt;idx&gt;</code>.
    </p>
    {% endif %}
    <p>Details:</p>
    <table cellpadding="4" style="border-collapse: collapse;">
      <thead>
        <tr>
          <th align="left">Ticket</th>
          <th align="left">Action</th>
          <th align="left">Version</th>
          <th align="left">State</th>
          <th align="left">Detail</th>
        </tr>
      </thead>
      <tbody>
        {% for t in tickets %}
        <tr>
          <td>{{ t.idx }}</td>
          <td>{{ t.action_id }}</td>
          <td>{{ t.action_version }}</td>
          <td>{{ t.state }}</td>
          <td>{{ t.failure_reason or "" }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if overflow %}
    <p>... and {{ overflow }} more.</p>
    {% endif %}
    <p style="color: #888; font-size: 0.9em;">
      Generated at {{ generated_at }}.<br />
      This is an automated message from qiita-miint.
      {% if contact_email %}
      Questions? Reply to this email or write to
      <a href="mailto:{{ contact_email }}">{{ contact_email }}</a>.
      {% endif %}
    </p>
  </body>
</html>

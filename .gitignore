# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Rust
target/

# OS
.DS_Store

# Editors / IDEs
.idea/
.vscode/

# Secrets / env — the per-component templates are committed (`*.example`);
# the stripped-suffix copies local dev / prod operators edit are not.
.env.control-plane
.env.data-plane
.env.compute-orchestrator
*.local

# Build artifacts
*.sif

# Local-only scratch space — large datasets the system tests consume
# (e.g. GG2 backbone FASTA + taxonomy + tree at ~11 GB). Never committed.
localdocs/

# Claude Code (workspace-local config and agent definitions)
# Ignore the workspace-local bits (settings, agents, worktrees) but TRACK the
# shared slash commands so every dev gets /deploy-note, /deploy-archive, etc.
.claude/*
!.claude/commands/

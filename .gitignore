# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
.ruff_cache/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Rust
target/

# OS
.DS_Store

# Editors / IDEs
.idea/
.vscode/

# Secrets / env — the per-component templates are committed (`*.example`);
# the stripped-suffix copies local dev / prod operators edit are not.
.env.control-plane
.env.data-plane
.env.compute-orchestrator
*.local

# Build artifacts
*.sif

# Local-only scratch space — large datasets the system tests consume
# (e.g. GG2 backbone FASTA + taxonomy + tree at ~11 GB). Never committed.
localdocs/

# Claude Code (workspace-local config and agent definitions)
# Ignore the workspace-local bits (per-dev settings, agents, worktrees) but TRACK
# the shared agent-facing config, so every dev's agent behaves the same:
#   commands/      — /deploy-note, /deploy-archive
#   settings.json  — shared config; settings.local.json stays per-dev and ignored
.claude/*
!.claude/commands/
!.claude/settings.json

# Qiita local-development environment variables.
#
# Usage:
#     cp .env.example .env
#     # edit .env and fill in required values
#     . .env
#
# `.env` is gitignored; `.env.example` (this file) is the committed template.
# Restart any running service after editing values.
#
# Required variables are uncommented with placeholder values.
# Optional variables are commented out and show the default, where one exists.

# ----- qiita-control-plane -----

# Postgres URL for the control-plane application DB.
# `dbmate up` (via `make migrate`) creates the target database if it is absent.
# Homebrew Postgres defaults to your macOS login name with no password.
export DATABASE_URL='postgresql://your-macos-username@localhost:5432/qiita'

# Base64-encoded HMAC key used to sign Flight tickets.
# Must decode to at least 16 bytes; generate with: openssl rand -base64 32
# Shared with qiita-data-plane — both services must see the same value.
export HMAC_SECRET_KEY='replace-with-output-of-openssl-rand-base64-32'

# Optional: gRPC URL for reaching the data plane.
# export DATA_PLANE_URL='grpc://localhost:50051'

# ----- qiita-compute-orchestrator -----

# REST URL of the control plane, for callbacks.
export CONTROL_PLANE_URL='http://localhost:8080'

# Optional overrides (defaults shown).
# export COMPUTE_BACKEND='local'
# export SHARED_FILESYSTEM_ROOT="$TMPDIR/qiita"
# export MIINT_EXTENSION_PATH=''

# ----- qiita-data-plane -----
# HMAC_SECRET_KEY (above) is also required here.

# Postgres connection string for the DuckLake catalog.
# Libpq keyword/value format, not a URL.
export DUCKLAKE_CATALOG_CONNSTR='dbname=qiita_ducklake host=localhost port=5432 user=your-macos-username'

# Optional overrides (defaults shown).
# export LISTEN_ADDR='0.0.0.0:50051'
# export DUCKLAKE_DATA_PATH="$TMPDIR/qiita/ducklake"
# export JWKS_URL=''
